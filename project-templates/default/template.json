{
  "id": "default",
  "label": "General Project Template",
  "description": "General-purpose AgentCraft project template for research, planning, analysis, writing, synthesis, operations, and delivery workflows. It keeps the shared owner, lead, planner, worker, reviewer, PM, security, and integrator roles while routing local agents through local Docker Pi by default.",
  "version": "0.1",
  "settings": {
    "maxActiveAgents": 10,
    "maxActiveGoals": 5
  },
  "roleLaunchProfiles": [
    {
      "role": "LEAD_AGENT",
      "launchMode": "local-docker",
      "agentType": "pi",
      "deploymentDays": 1
    },
    {
      "role": "PLANNER_AGENT",
      "launchMode": "local-docker",
      "agentType": "pi",
      "deploymentDays": 1
    },
    {
      "role": "WORKER_AGENT",
      "launchMode": "local-docker",
      "agentType": "pi",
      "deploymentDays": 1
    },
    {
      "role": "REVIEW_AGENT",
      "launchMode": "local-docker",
      "agentType": "pi",
      "deploymentDays": 1
    },
    {
      "role": "SECURITY_AUDITOR",
      "launchMode": "local-docker",
      "agentType": "pi",
      "deploymentDays": 1
    },
    {
      "role": "PM_AGENT",
      "launchMode": "local-docker",
      "agentType": "pi",
      "deploymentDays": 1
    },
    {
      "role": "AGGREGATOR_AGENT",
      "launchMode": "local-docker",
      "agentType": "pi",
      "deploymentDays": 1
    },
    {
      "role": "INTEGRATOR_AGENT",
      "launchMode": "local-docker",
      "agentType": "pi",
      "deploymentDays": 1
    }
  ],
  "projectFileFolders": [
    "inputs",
    "research",
    "work",
    "deliverables",
    "reviews",
    "coordination",
    "scratch"
  ],
  "workItemStatusFlow": {
    "initialStatus": "READY",
    "activeStatus": "IN_PROGRESS",
    "assignmentCompletedStatus": "IN_REVIEW",
    "assignmentFailedStatus": "NEEDS_REVISION",
    "reviewApprovedStatus": "ACCEPTED",
    "reviewChangesRequestedStatus": "NEEDS_REVISION",
    "reviewRejectedStatus": "REJECTED",
    "closedStatus": "CANCELLED",
    "statuses": [
      {
        "id": "READY",
        "label": "待领取",
        "category": "claimable",
        "initial": true
      },
      {
        "id": "ASSIGNED",
        "label": "已分配",
        "category": "active"
      },
      {
        "id": "IN_PROGRESS",
        "label": "处理中",
        "category": "active"
      },
      {
        "id": "IN_REVIEW",
        "label": "待反馈",
        "category": "feedback"
      },
      {
        "id": "NEEDS_REVISION",
        "label": "需修改",
        "category": "claimable"
      },
      {
        "id": "ACCEPTED",
        "label": "完成",
        "category": "completed",
        "terminal": true,
        "completed": true
      },
      {
        "id": "REJECTED",
        "label": "关闭",
        "category": "closed",
        "terminal": true,
        "closed": true
      },
      {
        "id": "CANCELLED",
        "label": "关闭",
        "category": "closed",
        "terminal": true,
        "closed": true
      }
    ],
    "dispatchRules": [
      {
        "statuses": ["READY", "NEEDS_REVISION"],
        "workTypes": ["INTAKE", "PLANNING"],
        "role": "PLANNER_AGENT",
        "maxAgents": 2,
        "forceLaunchNew": false,
        "objective": "Turn an intake or planning item into concrete goals, feature groups, and executable work items."
      },
      {
        "statuses": ["READY", "NEEDS_REVISION"],
        "workTypes": ["RESEARCH", "ANALYSIS", "EXECUTION", "DRAFT", "WRITING", "DATA_PREP", "GENERAL_TASK"],
        "role": "WORKER_AGENT",
        "maxAgents": 10,
        "forceLaunchNew": false,
        "objective": "Execute the scoped research, analysis, writing, data preparation, or general task; write required artifacts; verify the result; and hand it off for review."
      },
      {
        "statuses": ["READY", "NEEDS_REVISION"],
        "workTypes": ["SECURITY_REVIEW"],
        "role": "SECURITY_AUDITOR",
        "maxAgents": 2,
        "forceLaunchNew": true,
        "objective": "Audit the referenced implementation, artifact, or plan for security risks and report concrete findings."
      },
      {
        "statuses": ["READY", "NEEDS_REVISION"],
        "workTypes": ["AGGREGATION", "SYNTHESIS", "REPORT", "DELIVERY", "DECISION_PACKAGE"],
        "role": "AGGREGATOR_AGENT",
        "maxAgents": 2,
        "forceLaunchNew": false,
        "objective": "Aggregate accepted upstream items, preserve source links and caveats, and prepare the requested grounded report, delivery, or decision package."
      },
      {
        "statuses": ["READY", "NEEDS_REVISION"],
        "workTypes": ["INTEGRATION"],
        "role": "INTEGRATOR_AGENT",
        "maxAgents": 2,
        "forceLaunchNew": false,
        "objective": "Connect accepted project work to allowed external systems, releases, CI, GitHub, or protected handoff workflows."
      },
      {
        "statuses": ["READY", "NEEDS_REVISION"],
        "workTypes": ["COORDINATION_CHECK", "RISK_CHECK", "STATUS_REVIEW"],
        "role": "PM_AGENT",
        "maxAgents": 1,
        "forceLaunchNew": false,
        "objective": "Inspect coordination health, risks, blockers, owner actions, and next-step clarity for the project."
      },
      {
        "statuses": ["IN_REVIEW"],
        "role": "REVIEW_AGENT",
        "maxAgents": 3,
        "forceLaunchNew": false,
        "objective": "Review the completed handoff against the work item's acceptance criteria and requested evidence."
      },
      {
        "statuses": ["READY", "NEEDS_REVISION"],
        "role": "WORKER_AGENT",
        "maxAgents": 10,
        "forceLaunchNew": false,
        "objective": "Execute the scoped work item, write required artifacts, verify the result, and hand it off for review."
      }
    ],
    "coordinator": {
      "enabled": true,
      "minAgents": 0,
      "maxAgents": 10,
      "maxDispatchesPerTick": 3,
      "launchMode": "local-docker",
      "agentType": "pi",
      "maxAgentsByRole": {
        "PLANNER_AGENT": 2,
        "WORKER_AGENT": 10,
        "REVIEW_AGENT": 3,
        "SECURITY_AUDITOR": 2,
        "PM_AGENT": 1,
        "AGGREGATOR_AGENT": 2,
        "INTEGRATOR_AGENT": 2
      }
    }
  },
  "roles": [
    {
      "role": "OWNER",
      "ref": "role://owner",
      "auto": "OWNER",
      "launchable": false,
      "description": "Human project owner. Created from the user who creates the project."
    },
    {
      "role": "COORDINATOR",
      "launchable": false,
      "label": "Coordinator",
      "description": "System default role that reads template work-item status rules, project/member capacity, and model API availability, then dispatches matching launchable roles."
    },
    {
      "role": "LEAD_AGENT",
      "ref": "role://lead-agent",
      "auto": "ON_CREATE",
      "launchable": false,
      "description": "Coordinates the project. Auto-provisioned on project creation."
    },
    {
      "role": "PLANNER_AGENT",
      "ref": "role://planner-agent",
      "launchable": true,
      "description": "Breaks goals into optional feature groups and ready work items."
    },
    {
      "role": "WORKER_AGENT",
      "ref": "role://worker-agent",
      "launchable": true,
      "description": "Executes assigned work and returns handoff evidence."
    },
    {
      "role": "REVIEW_AGENT",
      "ref": "role://review-agent",
      "launchable": true,
      "description": "Reviews handoffs against acceptance criteria."
    },
    {
      "role": "SECURITY_AUDITOR",
      "ref": "role://security-auditor",
      "launchable": true,
      "description": "Audits implementation work for security risks."
    },
    {
      "role": "PM_AGENT",
      "ref": "role://pm-agent",
      "launchable": true,
      "description": "Watches stalls, risks, load, and coordination health."
    },
    {
      "role": "AGGREGATOR_AGENT",
      "ref": "role://aggregator-agent",
      "launchable": true,
      "description": "Synthesizes accepted upstream work into grounded reports, deliveries, and decision packages."
    },
    {
      "role": "INTEGRATOR_AGENT",
      "ref": "role://integrator-agent",
      "launchable": true,
      "description": "Connects accepted work to external systems (GitHub, CI, releases)."
    }
  ],
  "projectGlobals": [
    {
      "key": "max_active_items",
      "label": "Max Active Items",
      "description": "Maximum number of non-terminal work items allowed in this project. The API caps this value at 300.",
      "value": "300",
      "isSecret": false,
      "required": false,
      "createTaskOnMissing": false,
      "category": "project-limits"
    }
  ]
}
